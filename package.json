{
  "name": "01_jira_dash",
  "private": true,
  "version": "1.0.55",
  "description": "Jira Dashboard Application",
  "author": "Okestro",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup-jira-config.cjs",
    "setup:all": "npm install && npm run setup",
    "dev": "vite",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "npm run build:icons && tsc -b && vite build && electron-builder",
    "build:icons": "node scripts/png-to-ico.cjs",
    "build:licenses": "node scripts/generate-third-party-licenses.cjs",
    "clean": "node scripts/clean-install-output.cjs",
    "build:install": "npm run clean && npm run build:licenses && npm run build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "start": "concurrently -n proxy,vite -c blue,green \"node proxy-server.cjs\" \"vite\"",
    "git:setup": "powershell -ExecutionPolicy Bypass -File scripts/git-setup.ps1",
    "git:push": "powershell -ExecutionPolicy Bypass -File scripts/git-push.ps1"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-holidays": "^3.27.0",
    "express": "^5.2.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.2",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.okestro.jiradash",
    "productName": "Jira Dashboard",
    "copyright": "Copyright © Okestro",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraFiles": [
      {
        "from": "jira-proxy-config.example.json",
        "to": "jira-proxy-config.example.json"
      },
      {
        "from": "build/INSTALL-KO.txt",
        "to": "INSTALL-KO.txt"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE.txt"
      },
      {
        "from": "NOTICE",
        "to": "NOTICE.txt"
      },
      {
        "from": "build/THIRD-PARTY-LICENSES.txt",
        "to": "THIRD-PARTY-LICENSES.txt"
      }
    ],
    "releaseInfo": {
      "releaseNotes": "v1.0.55 — 지연 정의 통일 + 반려 의미 재정의. (1) jira-helpers에 isActive/isDelayed/isCancelled/isOnHold/isRejected 헬퍼 추가. (2) 지연 = 'duedate < now AND active' 통일 — 취소·보류는 지연 제외 (작업 폐기/능동적 정지), 반려는 active 포함 (리더 수정 지시 = 재작업 필요). (3) 프로젝트 통계 담당자 분류에서 반려를 inProgress 그룹으로 이동 (이전 cancelled와 동일 처리 폐기). (4) 지연율 분모를 active 모집단으로 정정. (5) 매니저 콘솔 todayDue/dueSoonNext3Days도 active 기준으로 통일 (보류 이슈 노이즈 제거). 412 테스트 통과."
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jira Dashboard",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "uninstallDisplayName": "Jira Dashboard",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "zip",
      "category": "public.app-category.productivity"
    }
  }
}
